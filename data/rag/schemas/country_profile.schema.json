{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "country_profile.schema.json",
  "title": "Country RAG Profile",
  "type": "object",
  "required": ["country_code", "country_name", "version", "last_updated", "sections", "source_notes", "confidence"],
  "properties": {
    "country_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "country_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "last_updated": {
      "type": "string"
    },
    "sections": {
      "type": "object"
    },
    "source_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "object",
      "required": ["overall", "weak_sections"],
      "properties": {
        "overall": {
          "enum": ["low", "medium", "high", "unknown"]
        },
        "weak_sections": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
