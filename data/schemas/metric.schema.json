{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metric.schema.json",
  "title": "Metadata-backed metric",
  "type": "object",
  "required": [
    "metric_id",
    "country_code",
    "value",
    "unit",
    "year",
    "source_name",
    "source_url",
    "retrieved_at",
    "calculation",
    "confidence",
    "freshness_requirement",
    "notes"
  ],
  "properties": {
    "metric_id": { "type": "string" },
    "country_code": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "value": {},
    "unit": { "type": ["string", "null"] },
    "year": { "type": ["integer", "null"] },
    "source_name": { "type": ["string", "null"] },
    "source_url": { "type": ["string", "null"] },
    "retrieved_at": { "type": ["string", "null"] },
    "calculation": { "type": ["string", "null"] },
    "confidence": { "enum": ["low", "medium", "high", "unknown"] },
    "freshness_requirement": { "type": "string" },
    "notes": { "type": "string" }
  }
}
