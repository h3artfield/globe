{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rag_chunk.schema.json",
  "title": "RAG chunk",
  "type": "object",
  "required": [
    "chunk_id",
    "country_code",
    "relationship_id",
    "module",
    "text",
    "tags",
    "source_ids",
    "claim_type",
    "year_range",
    "freshness",
    "confidence"
  ],
  "properties": {
    "chunk_id": { "type": "string" },
    "country_code": { "type": ["string", "null"], "pattern": "^[A-Z]{3}$" },
    "relationship_id": { "type": ["string", "null"], "pattern": "^[A-Z]{3}_[A-Z]{3}$" },
    "module": { "type": "string" },
    "text": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "source_family": { "type": "string" },
    "authority_rank": { "type": "string" },
    "can_override_official_data": { "type": "boolean" },
    "retrieval_priority": { "type": "number" },
    "claim_type": {
      "enum": ["fact", "interpretation", "adversary_narrative", "strategic_inference", "metric", "scenario", "baseline_summary"]
    },
    "year_range": {
      "type": ["array", "null"],
      "prefixItems": [{ "type": "integer" }, { "type": "integer" }]
    },
    "freshness": { "type": "string" },
    "confidence": { "enum": ["low", "medium", "high", "unknown"] }
  }
}
